RewriteEngine On
DirectoryIndex index.html

# Force old alternate homepage to main homepage
RewriteRule ^index-2(?:\.html)?$ / [R=301,L]

# Redirect direct .html requests to extensionless URLs
RewriteCond %{THE_REQUEST} \s/+(.*?)\.html[\s?] [NC]
RewriteRule ^ %1 [R=301,L]

# Serve extensionless URLs from matching .html files
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

# Treat root as index.html
RewriteRule ^$ index.html [L]
