RewriteEngine On
DirectoryIndex index.html

<IfModule mod_headers.c>
	<FilesMatch "\.(html?)$">
		Header set Cache-Control "no-cache, no-store, must-revalidate"
		Header set Pragma "no-cache"
		Header set Expires "0"
	</FilesMatch>
</IfModule>

# Force index variants to main homepage
RewriteRule ^index(?:\.html)?$ / [R=301,L]

# Force old alternate homepage to main homepage
RewriteRule ^index-2(?:\.html)?$ / [R=301,L]

# Redirect direct .html requests to extensionless URLs
RewriteCond %{THE_REQUEST} \s/+(.*?)\.html[\s?] [NC]
RewriteRule ^ %1 [R=301,L]

# Serve extensionless URLs from matching .html files
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

# Treat root as index.html
RewriteRule ^$ index.html [L]
